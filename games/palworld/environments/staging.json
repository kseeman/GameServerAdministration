{
  "metadata": {
    "environment": "staging",
    "description": "Staging environment configuration for Palworld servers",
    "version": "1.0",
    "created": "2026-03-22T15:36:00Z"
  },
  "game": {
    "name": "Palworld",
    "docker_image": "thijsvanloef/palworld-server-docker:latest",
    "data_volume_path": "/palworld",
    "config_files": ["PalWorldSettings.ini"],
    "backup_includes": ["SaveGames", "Config"],
    "health_check": {
      "type": "rest_api",
      "endpoint": "/v1/api/info",
      "port": "restapi_port",
      "auth_required": false
    }
  },
  "server_infrastructure": {
    "base_server_name": "Vauldamir's Server (Staging)",
    "server_description_suffix": "Staging Environment - Testing Only",
    "admin_password": "admin_staging_2024",
    "base_password": "letsride-staging"
  },
  "network_config": {
    "base_ports": {
      "game_port": 9215,
      "query_port": 28019,
      "rcon_port": 26577,
      "restapi_port": 10999
    },
    "port_offset_per_instance": 10,
    "public_ip": "",
    "region": "US",
    "rcon_enabled": true
  },
  "docker_config": {
    "restart_policy": "unless-stopped",
    "memory_limit": "8g",
    "cpu_limit": "4"
  },
  "naming_conventions": {
    "volume_pattern": "palworld-vol-staging-{instance}",
    "container_pattern": "palworld-staging-{instance}",
    "backup_pattern": "{preset}_{instance}_staging_{timestamp}.tar.gz"
  },
  "backup_config": {
    "backup_retention": 10,
    "backup_schedule": "0 * * * *",
    "backup_location": "./backups/staging/{instance}/"
  },
  "instances": {
    "test": {
      "description": "Testing server instance",
      "default_preset": "default",
      "port_offset": 0,
      "max_players": 8
    },
    "tournament": {
      "description": "Tournament competition server (staging)",
      "default_preset": "tournament",
      "port_offset": 1,
      "max_players": 32
    },
    "hardcore": {
      "description": "Maximum difficulty PvP server (staging)",
      "default_preset": "hardcore",
      "port_offset": 2,
      "max_players": 20
    },
    "casual": {
      "description": "Relaxed gameplay server (staging)",
      "default_preset": "casual",
      "port_offset": 3,
      "max_players": 32
    },
    "main": {
      "description": "Main general-purpose server (staging)",
      "default_preset": "default",
      "port_offset": 4,
      "max_players": 32
    }
  }
}
