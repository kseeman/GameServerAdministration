{
  "metadata": {
    "environment": "production",
    "description": "Production environment configuration for Minecraft servers",
    "version": "1.0",
    "created": "2026-04-03T00:00:00Z"
  },
  "game": {
    "name": "Minecraft",
    "docker_image": "itzg/minecraft-server:latest",
    "data_volume_path": "/data",
    "config_files": ["server.properties"],
    "backup_includes": ["world", "server.properties"],
    "health_check": {
      "type": "mc-health",
      "port": "game_port"
    }
  },
  "server_infrastructure": {
    "base_server_name": "Vauldamir's Minecraft",
    "server_description_suffix": "",
    "admin_password": "",
    "rcon_password": "mc_rcon_prod_2024"
  },
  "network_config": {
    "base_ports": {
      "game_port": 25565,
      "query_port": 19132,
      "rcon_port": 25700,
      "restapi_port": 0
    },
    "port_offset_per_instance": 10,
    "public_ip": "",
    "region": "US",
    "rcon_enabled": true
  },
  "docker_config": {
    "restart_policy": "always",
    "memory_limit": "12g",
    "cpu_limit": "4"
  },
  "naming_conventions": {
    "volume_pattern": "minecraft-vol-production-{instance}",
    "container_pattern": "minecraft-production-{instance}",
    "backup_pattern": "{preset}_{instance}_production_{timestamp}.tar.gz"
  },
  "backup_config": {
    "backup_retention": 48,
    "backup_schedule": "0 */2 * * *",
    "backup_location": "./backups/production/{instance}/"
  },
  "instances": {
    "vanilla": {
      "description": "Vanilla",
      "default_preset": "default",
      "port_offset": 0,
      "max_players": 20
    },
    "pixelmon": {
      "description": "Pixelmon",
      "default_preset": "pixelmon",
      "port_offset": 1,
      "max_players": 20
    }
  }
}
