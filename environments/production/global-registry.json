{
  "environment": "production",
  "supported_games": {
    "palworld": {
      "name": "Palworld",
      "version": "latest",
      "base_ports": {
        "game_port": 8215,
        "query_port": 27019,
        "rcon_port": 25577,
        "restapi_port": 9999
      },
      "docker_image": "palworld-enhanced:latest",
      "data_path": "/opt/palworld/Pal/Saved",
      "config_path": "/opt/palworld/Pal/Saved/Config/LinuxServer",
      "backup_includes": ["SaveGames", "Config"],
      "health_check": {
        "type": "rest_api",
        "endpoint": "/v1/api/info",
        "port": "restapi_port",
        "auth_required": true
      }
    }
  },
  "naming_conventions": {
    "volume_pattern": "{game}-vol-{env}-{context}",
    "container_pattern": "{game}-{env}-{context}",
    "backup_pattern": "{context}_{env}_{timestamp}.tar.gz"
  },
  "port_allocation": {
    "production_range": "8000-8999",
    "staging_range": "9000-9999"
  }
}